VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App Check (optional). Set to a reCAPTCHA v3 site key to enable.
# Register the site key in Firebase Console → App Check → Web app.
VITE_FIREBASE_APPCHECK_RECAPTCHA_KEY=
# Dev-only: paste a debug token from the App Check console to bypass on localhost.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Strava integration (public values only — the client_secret lives in Functions secrets).
VITE_STRAVA_CLIENT_ID=
# The deployed stravaCallback function URL, e.g. https://<region>-<project>.cloudfunctions.net/stravaCallback
VITE_STRAVA_CALLBACK_URL=
