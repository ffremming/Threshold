rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasActiveStatus(userData) {
      return !('status' in userData) || userData.status == 'active';
    }

    function isActiveUser() {
      return userExists() && hasActiveStatus(getUserData());
    }

    function isValidStatus(status) {
      return status == 'active' || status == 'pending' || status == 'disabled';
    }

    function hasRole(role) {
      return isActiveUser() && (
        getUserData().role == role ||
        ('roles' in getUserData() && role in getUserData().roles)
      );
    }

    function isSuperadmin() {
      return hasRole('superadmin');
    }

    function isCoachOf(athleteId) {
      return isActiveUser()
        && exists(/databases/$(database)/documents/relationships/$(request.auth.uid + '_' + athleteId));
    }

    function canAccessAthlete(athleteId) {
      return isActiveUser() && (
        athleteId == request.auth.uid ||
        isSuperadmin() ||
        isCoachOf(athleteId)
      );
    }

    function isTemplateOwner(templateData) {
      return isActiveUser() && templateData.ownerId == request.auth.uid;
    }

    function isBuiltinTemplate(templateData) {
      return templateData.source == 'builtin';
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isValidSelfCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'workoutLayout',
          'role', 'roles', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string
        && request.resource.data.workoutLayout in ['list', 'calendar']
        && request.resource.data.role == 'athlete'
        && request.resource.data.roles is list
        && request.resource.data.roles.size() == 1
        && request.resource.data.roles[0] == 'athlete'
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidUserAdminUpdate() {
      return !changedKeys().hasAny(['uid', 'email', 'createdAt'])
        && (!('status' in request.resource.data) || isValidStatus(request.resource.data.status))
        && (!('roles' in request.resource.data) || request.resource.data.roles is list);
    }

    function isSafeProfileUpdate() {
      return changedKeys().hasOnly([
        'displayName', 'workoutLayout', 'maxHr', 'thresholdHr', 'vo2maxHr',
        'easyTempo', 'longTempo', 'results', 'updatedAt'
      ]);
    }

    // Users collection
    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        isSuperadmin() ||
        (hasRole('coach') && isCoachOf(userId)) ||
        // Athletes browse the coach directory to pick their own coaches.
        (isActiveUser() && 'coach' in resource.data.roles)
      );
      // New users may only self-create as pending athletes. A superadmin must
      // activate the profile before it can read or write training data.
      allow create: if isValidSelfCreate(userId);
      // Self/coach profile edits cannot change identity, roles, or status.
      // Superadmins can manage role and status but not rewrite immutable identity.
      allow update: if isActiveUser() && (
        (isSuperadmin() && isValidUserAdminUpdate()) ||
        (request.auth.uid == userId && isSafeProfileUpdate()) ||
        (isCoachOf(userId) && isSafeProfileUpdate())
      );
    }

    // Coach-Athlete Relationships
    match /relationships/{relationshipId} {
      allow read: if isActiveUser() && (
        isSuperadmin() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.athleteId == request.auth.uid
      );
      // Superadmins manage any link; athletes manage links where they are the athlete.
      allow create, update: if isActiveUser()
        && (isSuperadmin() || request.auth.uid == request.resource.data.athleteId)
        && request.resource.data.coachId is string
        && request.resource.data.athleteId is string
        && relationshipId == request.resource.data.coachId + '_' + request.resource.data.athleteId;
      allow delete: if isActiveUser()
        && (isSuperadmin() || resource.data.athleteId == request.auth.uid);
    }

    // Workouts
    match /workouts/{workoutId} {
      allow read: if canAccessAthlete(resource.data.athleteId);
      allow create: if isActiveUser()
        && request.resource.data.athleteId is string
        && canAccessAthlete(request.resource.data.athleteId);
      allow update: if canAccessAthlete(resource.data.athleteId)
        && request.resource.data.athleteId == resource.data.athleteId;
      allow delete: if canAccessAthlete(resource.data.athleteId);
    }

    // Templates (global, read by all authenticated, write by superadmin/coach)
    match /templates/{templateId} {
      allow read: if isActiveUser() && (
        isBuiltinTemplate(resource.data) ||
        isTemplateOwner(resource.data) ||
        isSuperadmin()
      );
      allow create: if isActiveUser() && (
        isSuperadmin() ||
        (
          hasRole('coach') &&
          request.resource.data.source == 'custom' &&
          isTemplateOwner(request.resource.data)
        )
      );
      allow update: if isActiveUser() && (
        isSuperadmin() ||
        (
          hasRole('coach') &&
          !isBuiltinTemplate(resource.data) &&
          isTemplateOwner(resource.data)
        )
      )
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.source == resource.data.source;
      allow delete: if isActiveUser() && (
        isSuperadmin() ||
        (
          hasRole('coach') &&
          !isBuiltinTemplate(resource.data) &&
          isTemplateOwner(resource.data)
        )
      );
    }

    // Global session library (read by all authenticated, write by superadmin only)
    match /globalTemplates/{templateId} {
      allow read: if isActiveUser();
      allow write: if isSuperadmin();
    }

    // Per-athlete session pool (coach maintains a session bank per athlete)
    match /athleteSessions/{sessionId} {
      allow read: if isActiveUser() && (
        isSuperadmin() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.athleteId == request.auth.uid ||
        isCoachOf(resource.data.athleteId)
      );
      allow create: if isActiveUser() && (
        isSuperadmin() ||
        (
          request.resource.data.coachId == request.auth.uid &&
          isCoachOf(request.resource.data.athleteId)
        )
      );
      allow update: if isActiveUser() && (
        isSuperadmin() ||
        (
          resource.data.coachId == request.auth.uid &&
          isCoachOf(resource.data.athleteId)
        )
      )
        && request.resource.data.coachId == resource.data.coachId
        && request.resource.data.athleteId == resource.data.athleteId;
      allow delete: if isActiveUser() && (
        isSuperadmin() ||
        (
          resource.data.coachId == request.auth.uid &&
          isCoachOf(resource.data.athleteId)
        )
      );
    }

    // Tests
    match /tests/{testId} {
      allow read: if canAccessAthlete(resource.data.athleteId);
      allow create: if isActiveUser()
        && request.resource.data.athleteId is string
        && canAccessAthlete(request.resource.data.athleteId);
      allow update: if canAccessAthlete(resource.data.athleteId)
        && request.resource.data.athleteId == resource.data.athleteId;
      allow delete: if canAccessAthlete(resource.data.athleteId);
    }

    match /completedActivities/{activityId} {
      // Imported and written only by Cloud Functions (Admin SDK bypasses rules).
      allow read: if canAccessAthlete(resource.data.athleteId);
      allow write: if false;
    }

    match /stravaConnections/{athleteId} {
      // Token storage. Read by owner/coach; never client-writable.
      allow read: if canAccessAthlete(athleteId);
      allow write: if false;
    }
  }
}
